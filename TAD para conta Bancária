#include <stdio.h>

typedef struct {
    int numero;
    float saldo;
} Conta;

// inicializar conta
void inicializarConta(Conta *c, int numero) {
    c->numero = numero;
    c->saldo = 0;
}

// deposito
void depositar(Conta *c, float valor) {
    c->saldo += valor;
}

// saque
void sacar(Conta *c, float valor) {

    if(valor <= c->saldo) {
        c->saldo -= valor;
        printf("Saque realizado\n");
    } else {
        printf("Saldo insuficiente\n");
    }

}

// imprimir saldo
void imprimirSaldo(Conta *c) {
    printf("Conta: %d\n", c->numero);
    printf("Saldo: %.2f\n", c->saldo);
}

int main() {

    Conta c1;

    inicializarConta(&c1, 123);
    depositar(&c1, 500);
    sacar(&c1, 500);
    imprimirSaldo(&c1);

    return 0;
}
